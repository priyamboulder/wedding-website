# ══════════════════════════════════════════════════════════════════
# Ananya — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════════

# ── Anthropic Claude API ──────────────────────────────────────────
# REQUIRED — Powers all 22+ AI features:
#   aesthetic synthesis, checklist generation, menu suggestions,
#   seating AI, receipt parsing, social content, review generation
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────
# REQUIRED — PostgreSQL database + auth + storage
# Get from: https://supabase.com → your project → Settings → API

# Server-side only (never exposed to browser):
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Browser-safe (anon/public key — read-only):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL ───────────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (update to your domain when deploying):
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Email (Resend) ────────────────────────────────────────────────
# REQUIRED for email features:
#   booking confirmations, RSVP notifications, inquiry replies,
#   vendor onboarding emails, creator approvals
#
# Get API key: https://resend.com → API Keys → Create
# For testing without a domain: use "onboarding@resend.dev" as FROM
# For production: verify your domain at resend.com/domains
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── AviationStack (Optional) ──────────────────────────────────────
# Used for live flight status in the Guest Travel tracker.
# Without this key, flights use deterministic mock data (UI works fully).
# Free tier: ~100 requests/month
# Get key: https://aviationstack.com → Sign Up → API Access Key
AVIATIONSTACK_API_KEY=

# ── Trigger.dev (Optional) ────────────────────────────────────────
# Used for background vendor enrichment jobs (not critical for core features).
# The app works fully without this — background jobs simply won't run.
# Get key: https://cloud.trigger.dev → your project → API Keys
TRIGGER_SECRET_KEY=

# ── Stripe (Optional) ─────────────────────────────────────────────
# Required for seller payouts and marketplace payments.
# Without this, payment flows show a "coming soon" state.
# Get keys: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Sentry (Recommended for production error monitoring) ──────────
# Get from: https://sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-project-name
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# ── Upstash Redis (Optional but recommended for production) ────────
# Replaces the in-memory rate limiter with a persistent distributed store.
# Without this, rate limiting resets on every serverless function cold start.
# Get from: https://upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ══════════════════════════════════════════════════════════════════
#
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Fill in ANTHROPIC_API_KEY, SUPABASE_*, NEXT_PUBLIC_SUPABASE_*
#    (minimum required to boot the app)
#
# 3. Run database migrations:
#    npx supabase db push
#    (or apply /supabase/migrations/*.sql manually in order)
#
# 4. Seed database with vendor/checklist/stationery data:
#    npx tsx scripts/seed-all.mjs
#    (or individual: npx tsx scripts/seed-vendors.mjs)
#
# 5. Create Supabase Storage bucket named "ananya-uploads":
#    Dashboard → Storage → New Bucket
#    Name: ananya-uploads  |  Public: ON
#
# 6. Add RESEND_API_KEY + RESEND_FROM_EMAIL for email features
#
# 7. Start development server:
#    npm run dev
#
# ══════════════════════════════════════════════════════════════════
